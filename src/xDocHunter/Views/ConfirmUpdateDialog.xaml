<Window x:Class="xDocHunter.Views.ConfirmUpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Index"
        Width="440" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="{DynamicResource UiFont}"
        FontSize="13"
        UseLayoutRounding="True">

    <Grid Margin="28,24,28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="24"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Border Background="{DynamicResource PrimarySoftBrush}"
                    CornerRadius="8" Width="36" Height="36"
                    Margin="0,0,14,0">
                <Image Source="/Assets/Icons/refresh.png" Width="16" Height="16"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Update Index" FontSize="15" FontWeight="SemiBold"/>
                <TextBlock Text="Re-scan root and overwrite the index file"
                           FontSize="11" Foreground="{DynamicResource MutedBrush}"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- Divider -->
        <Border Grid.Row="1" Height="1" Margin="0,8,0,8"
                Background="{DynamicResource BorderBrush}" VerticalAlignment="Center"/>

        <!-- File path row -->
        <Grid Grid.Row="2" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="FILE"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource SubtleBrush}"
                       VerticalAlignment="Center"/>
            <Border Grid.Column="1"
                    Background="{DynamicResource SecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="10,6">
                <TextBlock x:Name="FilePathText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource ForegroundBrush}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Grid>

        <!-- Root path row -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="ROOT"
                       FontSize="10" FontWeight="SemiBold"
                       Foreground="{DynamicResource SubtleBrush}"
                       VerticalAlignment="Center"/>
            <Border Grid.Column="1"
                    Background="{DynamicResource SecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="10,6">
                <TextBlock x:Name="RootPathText"
                           FontFamily="{DynamicResource MonoFont}"
                           FontSize="11"
                           Foreground="{DynamicResource MutedBrush}"
                           TextTrimming="CharacterEllipsis"
                           ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            </Border>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Cancel"
                    Style="{DynamicResource GhostButton}"
                    Padding="16,8"
                    Click="Cancel_Click"/>
            <Button Grid.Column="3" Content="Update"
                    Style="{DynamicResource PrimaryButton}"
                    Padding="20,8"
                    IsDefault="True"
                    Click="Update_Click"/>
        </Grid>
    </Grid>
</Window>
