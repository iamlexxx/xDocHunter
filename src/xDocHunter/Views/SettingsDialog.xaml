<Window x:Class="xDocHunter.Views.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="{DynamicResource UiFont}"
        FontSize="13"
        UseLayoutRounding="True">

    <StackPanel Margin="28,24,28,24">
        <!-- Title -->
        <TextBlock Text="Settings" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="Customize your xDocHunter experience."
                   Foreground="{DynamicResource MutedBrush}" FontSize="12"
                   Margin="0,0,0,24"/>

        <!-- APPEARANCE section -->
        <TextBlock Text="APPEARANCE" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,12"/>

        <!-- Dark Mode toggle -->
        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Dark mode" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Use dark color theme"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox x:Name="DarkModeToggle" Grid.Column="1"
                          VerticalAlignment="Center"
                          Checked="DarkModeToggle_Changed"
                          Unchecked="DarkModeToggle_Changed"
                          Style="{DynamicResource ToggleSwitch}"/>
            </Grid>
        </Border>

        <!-- BEHAVIOR section -->
        <TextBlock Text="BEHAVIOR" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtleBrush}" Margin="0,16,0,12"/>

        <!-- Expand tree on load toggle -->
        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Expand folders on load" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="Automatically expand all folders in the tree view"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,2,0,0"/>
                </StackPanel>
                <CheckBox x:Name="ExpandTreeToggle" Grid.Column="1"
                          VerticalAlignment="Center"
                          Checked="ExpandTreeToggle_Changed"
                          Unchecked="ExpandTreeToggle_Changed"
                          Style="{DynamicResource ToggleSwitch}"/>
            </Grid>
        </Border>

        <!-- SEARCH section -->
        <TextBlock Text="SEARCH" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtleBrush}" Margin="0,16,0,12"/>

        <!-- Default search mode -->
        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,8">
            <StackPanel>
                <TextBlock Text="Default search mode" FontWeight="SemiBold" FontSize="13"/>
                <TextBlock Text="Pre-selected mode in the Scan Options dialog"
                           FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,2,0,8"/>
                <StackPanel Orientation="Horizontal">
                    <RadioButton x:Name="DefaultModeFilenameRadio" GroupName="DefaultMode"
                                 Content="Filename" Margin="0,0,16,0"
                                 Checked="DefaultModeRadio_Changed"/>
                    <RadioButton x:Name="DefaultModeContentRadio" GroupName="DefaultMode"
                                 Content="Content"
                                 Checked="DefaultModeRadio_Changed"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- FILE HANDLING section -->
        <TextBlock Text="FILE HANDLING" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtleBrush}" Margin="0,16,0,12"/>

        <!-- Built-in PDF viewer toggle -->
        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Open PDFs inside xDocHunter" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock Text="View PDFs in a read-only window instead of the default app"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,2,0,0"/>
                    <TextBlock x:Name="WebView2DownloadLink"
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,2,0,0"
                               Visibility="Collapsed">
                        <Hyperlink NavigateUri="https://developer.microsoft.com/en-us/microsoft-edge/webview2/"
                                   RequestNavigate="WebView2Link_RequestNavigate">
                            Requires WebView2 — download here
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
                <CheckBox x:Name="PdfViewerToggle" Grid.Column="1"
                          VerticalAlignment="Center"
                          Checked="PdfViewerToggle_Changed"
                          Unchecked="PdfViewerToggle_Changed"
                          Style="{DynamicResource ToggleSwitch}"/>
            </Grid>
        </Border>

        <!-- DISPLAY section -->
        <TextBlock Text="DISPLAY" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtleBrush}" Margin="0,16,0,12"/>

        <!-- Trim Path toggle -->
        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="Trim path" FontWeight="SemiBold" FontSize="13"/>
                        <TextBlock Text="Remove a string from displayed file paths"
                                   FontSize="11" Foreground="{DynamicResource SubtleBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox x:Name="TrimPathToggle" Grid.Column="1"
                              VerticalAlignment="Center"
                              Checked="TrimPathToggle_Changed"
                              Unchecked="TrimPathToggle_Changed"
                              Style="{DynamicResource ToggleSwitch}"/>
                </Grid>
                <TextBox x:Name="TrimPathInput"
                         Tag="String to remove from paths…"
                         FontFamily="{DynamicResource MonoFont}"
                         FontSize="12"
                         Margin="0,10,0,0"
                         Visibility="Collapsed"
                         TextChanged="TrimPathInput_TextChanged"/>
            </StackPanel>
        </Border>

        <!-- Close button -->
        <Button Content="Close" HorizontalAlignment="Right"
                Style="{DynamicResource SecondaryButton}"
                Click="Close_Click" Margin="0,20,0,0"
                Padding="24,8"/>
    </StackPanel>
</Window>
