<Window x:Class="xDocHunter.Views.PdfViewerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="PDF Viewer"
        Icon="/Assets/Icons/app-icon.png"
        Width="1100" Height="800"
        MinWidth="520" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="{DynamicResource UiFont}"
        FontSize="13"
        UseLayoutRounding="True">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Padding="16,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource PrimarySoftBrush}"
                        CornerRadius="6" Padding="6" Margin="0,0,10,0">
                    <Image Source="/Assets/Icons/file.png" Width="14" Height="14"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock x:Name="FileNameText"
                               FontWeight="SemiBold" FontSize="13"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="FilePathText"
                               FontFamily="{DynamicResource MonoFont}"
                               FontSize="11"
                               Foreground="{DynamicResource SubtleBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="2"
                        Background="{DynamicResource PrimarySoftBrush}"
                        CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                    <TextBlock Text="READ-ONLY"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                </Border>
            </Grid>
        </Border>

        <!-- WEBVIEW2 PDF HOST -->
        <Grid Grid.Row="1" Background="Black">
            <wv2:WebView2 x:Name="Web"/>
            <StackPanel x:Name="StatusOverlay"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="Visible">
                <TextBlock Text="Loading PDF…"
                           HorizontalAlignment="Center"
                           FontSize="14"
                           Foreground="#CCCCCC"/>
                <TextBlock x:Name="StatusDetail"
                           HorizontalAlignment="Center"
                           FontSize="11" Margin="0,6,0,0"
                           Foreground="#888888"
                           TextWrapping="Wrap"
                           MaxWidth="480"
                           TextAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                Padding="16,8">
            <TextBlock Text="xDocHunter's built-in viewer cannot modify the source file. Use the viewer toolbar for zoom, search, and print."
                       FontSize="11"
                       Foreground="{DynamicResource SubtleBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>
    </Grid>
</Window>
