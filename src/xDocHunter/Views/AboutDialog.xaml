<Window x:Class="xDocHunter.Views.AboutDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About xDocHunter"
        Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource ForegroundBrush}"
        FontFamily="{DynamicResource UiFont}"
        FontSize="13"
        UseLayoutRounding="True">

    <StackPanel Margin="32,28,32,28">

        <!-- Icon + Name -->
        <StackPanel HorizontalAlignment="Center" Margin="0,0,0,16">
            <Border Background="{DynamicResource PrimarySoftBrush}"
                    CornerRadius="16" Padding="16"
                    HorizontalAlignment="Center" Margin="0,0,0,14">
                <Image Source="/Assets/Icons/search.png" Width="36" Height="36"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
            </Border>
            <TextBlock HorizontalAlignment="Center" FontSize="22" FontWeight="Bold">
                <Run Text="x" Foreground="{DynamicResource ForegroundBrush}"/><Run Text="DocHunter" Foreground="{DynamicResource PrimaryBrush}"/>
            </TextBlock>
            <TextBlock x:Name="VersionText" HorizontalAlignment="Center"
                       FontSize="12" Foreground="{DynamicResource SubtleBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Description -->
        <TextBlock Text="Privacy-first local file search — by name or content."
                   HorizontalAlignment="Center" TextAlignment="Center"
                   FontSize="13" Foreground="{DynamicResource MutedBrush}"
                   Margin="0,0,0,6"/>

        <!-- Author + Copyright -->
        <TextBlock Text="By Lex"
                   HorizontalAlignment="Center"
                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"
                   Margin="0,0,0,2"/>
        <TextBlock x:Name="CopyrightText"
                   HorizontalAlignment="Center"
                   FontSize="12" Foreground="{DynamicResource SubtleBrush}"
                   Margin="0,0,0,24"/>

        <!-- Divider -->
        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Margin="0,0,0,24"/>

        <!-- Update check -->
        <TextBlock Text="SOFTWARE UPDATE" FontSize="10" FontWeight="SemiBold"
                   Foreground="{DynamicResource SubtleBrush}" Margin="0,0,0,10"/>

        <Border Background="{DynamicResource CardBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1" CornerRadius="8"
                Padding="16,12" Margin="0,0,0,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Check for updates" FontWeight="SemiBold" FontSize="13"/>
                    <TextBlock x:Name="UpdateStatusText"
                               Text="Click to check for a newer version."
                               FontSize="11" Foreground="{DynamicResource SubtleBrush}"
                               Margin="0,2,0,0" TextWrapping="Wrap"/>
                </StackPanel>
                <Button x:Name="CheckUpdateButton" Grid.Column="1"
                        Content="Check"
                        Style="{DynamicResource SecondaryButton}"
                        Padding="14,6" FontSize="12"
                        VerticalAlignment="Center" Margin="12,0,0,0"
                        Click="CheckUpdate_Click"/>
            </Grid>
        </Border>

        <!-- Close -->
        <Button Content="Close" HorizontalAlignment="Right"
                Style="{DynamicResource PrimaryButton}"
                Click="Close_Click" Padding="24,8"/>

    </StackPanel>
</Window>
